{
  "name": "@vignu10/nilai",
  "version": "0.4.0",
  "description": "ADHD-friendly focus sessions for Claude Code via CLI skills",
  "type": "module",
  "bin": {
    "nilai": "dist/cli.js",
    "nilai-hook": "dist/hook.js"
  },
  "files": [
    "dist",
    "source/skills"
  ],
  "scripts": {
    "build": "tsdown && node -e \"['cli','hook'].forEach(f=>{const p='dist/'+f+'.js';const c=require('fs').readFileSync(p,'utf8');require('fs').writeFileSync(p,'#!/usr/bin/env node\\n'+c);require('fs').chmodSync(p,0o755)})\"",
    "setup": "node dist/cli.js setup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "skills",
    "adhd",
    "focus",
    "claude-code"
  ],
  "license": "MIT"
}
